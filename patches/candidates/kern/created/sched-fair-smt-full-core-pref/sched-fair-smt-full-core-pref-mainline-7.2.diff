+/*
+ * When an idle wakeup target only has an idle SMT thread (its core is
+ * partially busy) while the LLC still advertises a fully idle core,
+ * skip the fast-path return so the idle-core scan can place the wakee
+ * on a full core instead. Default disabled: opt in via
+ * /sys/kernel/debug/sched/features.
+ */
+SCHED_FEAT(SIS_PREFER_CORE, false)
