+ * the daemon if hugepages are globally off; the wake is harmless then.
+ */
+void khugepaged_enter_mm(struct mm_struct *mm)
+{
+	if (!hugepage_enabled())
+		return;
+	if (!mm_flags_test(MMF_VM_HUGEPAGE, mm))
+		__khugepaged_enter(mm);
+	/*
+	 * Collapse the throttle sleep so the kick actually interrupts it:
+	 * khugepaged_should_wakeup() is gated on khugepaged_sleep_expire, so a
+	 * bare wake while a scan_sleep is pending just re-sleeps (the daemon
+	 * almost always has other registered mms on a desktop).  Every in-tree
+	 * kick (scan/alloc_sleep_millisecs_store) zeroes it first; match them.
+	 */
+	khugepaged_sleep_expire = 0;
