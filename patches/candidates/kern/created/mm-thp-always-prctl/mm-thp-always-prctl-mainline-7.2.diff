+static int prctl_get_thp_always(unsigned long arg2, unsigned long arg3,
+				unsigned long arg4, unsigned long arg5)
+{
+	if (!IS_ENABLED(CONFIG_64BIT))
+		return -EINVAL;	/* MMF_THP_ALWAYS is 64-bit only */
+	if (arg2 || arg3 || arg4 || arg5)
+		return -EINVAL;
+	return !!mm_flags_test(MMF_THP_ALWAYS, current->mm);
+}
+
+static int prctl_set_thp_always(unsigned long thp_always, unsigned long arg3,
+				unsigned long arg4, unsigned long arg5)
+{
+	struct mm_struct *mm = current->mm;
+
+	if (!IS_ENABLED(CONFIG_64BIT))
+		return -EINVAL;	/* MMF_THP_ALWAYS is 64-bit only */
+	if (arg3 || arg4 || arg5)
+		return -EINVAL;
+	if (mmap_write_lock_killable(mm))
+		return -EINTR;
+	if (thp_always)
+		mm_flags_set(MMF_THP_ALWAYS, mm);
+	else
+		mm_flags_clear(MMF_THP_ALWAYS, mm);
+	mmap_write_unlock(mm);
+	/*
+	 * Register with and wake khugepaged so an already-populated
+	 * heap starts collapsing within a wakeup rather than after the
+	 * next 10s scan cycle.  No-op when clearing / when THP is off.
+	 */
+	if (thp_always)
+		khugepaged_enter_mm(mm);
+	return 0;
+}
