diff --git a/include/linux/mm_types.h b/include/linux/mm_types.h
index b18c2b2e7d2c..edc65bd243d4 100644
--- a/include/linux/mm_types.h
+++ b/include/linux/mm_types.h
@@ -1982,6 +1982,43 @@ enum {
 #define MMF_TOPDOWN		31	/* mm searches top down by default */
 #define MMF_TOPDOWN_MASK	BIT(MMF_TOPDOWN)
 
+/*
+ * MMF_THP_ALWAYS: treat every THP-eligible anonymous VMA in this mm as if
+ * madvise(MADV_HUGEPAGE) had been called on it -- hugepages are allowed
+ * under the global "madvise" policy and allocated with synchronous
+ * compaction ("defrag=always" behaviour).  Set via prctl(PR_SET_THP_ALWAYS)
+ * and inherited across fork()/exec(): the bit sits above the legacy flags
+ * word, so mm_init() propagates it explicitly rather than via
+ * MMF_INIT_LEGACY_MASK.  MMF_DISABLE_THP_COMPLETELY /
+ * MMF_DISABLE_THP_EXCEPT_ADVISED and per-VMA VM_NOHUGEPAGE take precedence
+ * (applied by vma_thp_disabled() inside __thp_vma_allowable_orders(),
+ * after the hint has widened the order mask).
+ *
+ * The feature is 64-bit only, matching the original UAPI: the prctls
+ * return -EINVAL on 32-bit and every flag read is gated on
+ * IS_ENABLED(CONFIG_64BIT), so the bit can never be set there (even
+ * though the mm_flags_t bitmap itself could now hold it).
+ *
+ * KNOWN LIMITATIONS (non-blocking; for upstream discussion):
+ *  (a) The hint is inherited across exec() (matching MMF_DISABLE_THP_*),
+ *      but unlike DISABLE it *inflates* resource use, so it flows into an
+ *      exec'd setuid binary that never asked for it.  Kept as-is for
+ *      symmetry with THP_DISABLE; a launcher should set it as late as
+ *      possible and children may clear it or use MADV_NOHUGEPAGE.
+ *  (b) An unprivileged flagged process that keeps faulting/freeing anon
+ *      pages can hold khugepaged unthrottled (see the sleep-skip in
+ *      khugepaged_wait_work()), amplifying scan work up to ~max_ptes_none
+ *      (511) PTEs per collapse attempt.  khugepaged runs at MAX_NICE, so
+ *      this is a fairness, not a liveness, concern.
+ *  (c) The sleep-skip can carry one stale back-to-back pass after a flagged
+ *      process exits (the progress flag outlives the mm by a pass).
+ *  (d) There is no scan-list reprioritisation: a freshly-flagged mm is
+ *      scanned in list order, so time-to-first-collapse on a busy scan
+ *      list is unbounded (the measured ON-side bimodality).
+ */
+#define MMF_THP_ALWAYS		32
+static_assert(MMF_THP_ALWAYS < NUM_MM_FLAG_BITS);
+
 #define MMF_INIT_LEGACY_MASK	(MMF_DUMP_FILTER_MASK |\
 				 MMF_DISABLE_THP_MASK | MMF_HAS_MDWE_MASK |\
 				 MMF_VM_MERGE_ANY_MASK | MMF_TOPDOWN_MASK)
