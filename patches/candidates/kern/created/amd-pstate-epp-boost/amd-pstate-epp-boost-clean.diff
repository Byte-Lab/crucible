diff --git a/drivers/cpufreq/amd-pstate.c b/drivers/cpufreq/amd-pstate.c
index b2cf783b7895..36565a11dbc0 100644
--- a/drivers/cpufreq/amd-pstate.c
+++ b/drivers/cpufreq/amd-pstate.c
@@ -1447,6 +1447,214 @@ static bool amd_pstate_acpi_pm_profile_undefined(void)
 	return false;
 }
 
+/*
+ * Dynamic EPP boost for the active (EPP) mode.
+ *
+ * In active mode the platform autonomously picks the operating point
+ * between min_perf and max_perf, biased by the EPP hint; the kernel only
+ * rewrites the CPPC request on policy/limit changes.  Workloads dominated
+ * by one mostly-busy thread that takes frequent short sleeps (e.g. a game
+ * render thread blocking on a futex waiting for the GPU or a worker thread
+ * every frame) defeat the platform's utilization tracking: each sleep
+ * decays the hardware's performance signal, so post-wakeup bursts start at
+ * a low operating point and the frame-time *tail* inflates even though the
+ * CPU is ~100% busy at the frame timescale.
+ *
+ * A global EPP=performance (energy_performance_preference = performance,
+ * EPP=0) fixes that tail cleanly, but at the cost of every core and every
+ * workload.  A min_perf floor that pins a busy core >= nominal_perf was
+ * measured to raise the median frequency identically yet *regress* the
+ * p999 frame-time tail on a Steam Deck (Van Gogh APU): pinning min high
+ * during micro-idle / vsync waits perturbs the shared CPU/GPU SMU boost
+ * management.  So this applies the proven lever - the EPP hint - per-core
+ * and only while busy, and leaves min/des/max untouched.
+ *
+ * When the dynamic_epp module parameter is enabled, track per-CPU C0
+ * residency (delta MPERF / delta TSC) from a cpufreq update-util hook,
+ * sampled at most every AMD_PSTATE_DYNAMIC_EPP_SAMPLE_NS.  While a CPU has
+ * been >= AMD_PSTATE_DYNAMIC_EPP_BUSY_PCT busy within the last
+ * AMD_PSTATE_DYNAMIC_EPP_DECAY_NS, its EPP byte is set to
+ * AMD_CPPC_EPP_PERFORMANCE; on decay the policy EPP (typically
+ * balance_performance) is restored.  It self-limits: a genuinely idle or
+ * lightly loaded CPU stops refreshing the busy timestamp and the boost
+ * decays away.
+ *
+ * This mirrors intel_pstate's hwp_boost update-util hook in autonomous
+ * mode.  hwp_boost keys off SCHED_CPUFREQ_IOWAIT, which futex/GPU-fence
+ * waits never set, so a C0-residency trigger is used here instead.
+ *
+ * The boost is applied on top of cppc_req_cached and never written back to
+ * it: all other active-mode writers of MSR_AMD_CPPC_REQ (limit updates via
+ * msr_update_perf(), EPP stores via msr_set_epp()) keep working purely from
+ * the cached "policy" value, so cppc_req_cached always holds the policy EPP
+ * and a release restores exactly that.  The boost is purely edge-triggered:
+ * written once when a busy period starts and restored once when it ends,
+ * with no per-sample re-write.  A concurrent limit/EPP update therefore
+ * drops the boost until the next activation edge, which is acceptable
+ * because those updates do not occur during steady gaming.
+ *
+ * The boost breaks the "MSR == cppc_req_cached" invariant while active, so
+ * the msr_update_perf() value==prev dedup could otherwise skip a
+ * suspend/offline/exit bios_min_perf reset while the MSR still holds EPP=0.
+ * amd_pstate_dynamic_epp_clear() restores the invariant (and is called
+ * before every such reset) to keep the dedup honest.
+ *
+ * MSR (X86_FEATURE_CPPC) systems only: the hook must run on the local CPU
+ * (it does local rdmsr/wrmsr via amd_pstate_sample() and a bare wrmsrq),
+ * so remote callbacks are rejected; the shared-memory (PCC mailbox) path
+ * cannot run from this context at all and is never registered.
+ */
+static bool dynamic_epp __read_mostly;
+module_param(dynamic_epp, bool, 0644);
+MODULE_PARM_DESC(dynamic_epp,
+		 "boost EPP toward performance on recently-busy CPUs (active mode, MSR systems only)");
+
+#define AMD_PSTATE_DYNAMIC_EPP_SAMPLE_NS	(10 * NSEC_PER_MSEC)
+/*
+ * Widened decay + lowered busy threshold so a render thread that is only
+ * ~50-80% busy (periodic vsync/GPU-fence waits every frame) does not
+ * deactivate mid-benchmark: the boost activates once and stays for the busy
+ * period, at ~1-2 CPPC_REQ writes total.
+ */
+#define AMD_PSTATE_DYNAMIC_EPP_DECAY_NS		(300 * NSEC_PER_MSEC)
+#define AMD_PSTATE_DYNAMIC_EPP_BUSY_PCT		50
+
+static void amd_pstate_dynamic_epp_apply(struct amd_cpudata *cpudata, u64 cached)
+{
+	union perf_cached perf = READ_ONCE(cpudata->perf);
+
+	/*
+	 * Registration precedes the first ->set_policy() that populates the
+	 * limit perf values.  Skip until the policy is live so we never boost
+	 * EPP on a half-initialized request.
+	 */
+	if (!perf.max_limit_perf)
+		return;
+
+	/*
+	 * Bias the EPP hint toward performance for this recently-busy core,
+	 * exactly what `echo performance > energy_performance_preference` does
+	 * (EPP=0), but per-core and only while busy.  min/des/max are left at
+	 * their policy values: unlike a min_perf floor this does NOT pin the
+	 * core >= nominal during micro-idle/vsync waits, which is what perturbed
+	 * Van Gogh's shared CPU/GPU SMU boost management and cost the p999 tail.
+	 * EPP lives in bits [31:24] of MSR_AMD_CPPC_REQ (AMD_CPPC_EPP_PERF_MASK).
+	 *
+	 * @cached is snapshotted from cppc_req_cached by the caller.  A limit/EPP
+	 * writer updates that cache only after its wrmsrq_on_cpu() IPI returns,
+	 * so on this activation edge @cached may briefly still carry the pre-
+	 * update min/max; the discrepancy is at most one in-flight update and is
+	 * healed when the boost is released (the whole cached request is
+	 * rewritten) or on the writer's next update.
+	 */
+	cached &= ~AMD_CPPC_EPP_PERF_MASK;
+	cached |= FIELD_PREP(AMD_CPPC_EPP_PERF_MASK, AMD_CPPC_EPP_PERFORMANCE);
+
+	wrmsrq(MSR_AMD_CPPC_REQ, cached);
+}
+
+static void amd_pstate_dynamic_epp_release(struct amd_cpudata *cpudata)
+{
+	/*
+	 * cppc_req_cached still holds the policy EPP since the boost never
+	 * writes it back, so restoring the whole cached request restores exactly
+	 * the EPP the policy last set.
+	 */
+	wrmsrq(MSR_AMD_CPPC_REQ, READ_ONCE(cpudata->cppc_req_cached));
+}
+
+/*
+ * Restore MSR == cppc_req_cached from any context (cross-CPU safe).  Called
+ * before the suspend/offline/exit bios_min_perf resets so their value==prev
+ * dedup cannot skip a real write while the MSR still carries the boost.
+ */
+static void amd_pstate_dynamic_epp_clear(struct amd_cpudata *cpudata)
+{
+	if (!cpudata->dyn_epp_active)
+		return;
+
+	wrmsrq_on_cpu(cpudata->cpu, MSR_AMD_CPPC_REQ,
+		      READ_ONCE(cpudata->cppc_req_cached));
+	cpudata->dyn_epp_active = false;
+}
+
+static void amd_pstate_dynamic_epp_update_util(struct update_util_data *data,
+					       u64 time, unsigned int flags)
+{
+	struct amd_cpudata *cpudata = container_of(data, struct amd_cpudata,
+						   dyn_epp_update_util);
+	union perf_cached perf;
+	u64 busy_pct;
+	bool active;
+
+	/*
+	 * Don't allow remote callbacks: update-util hooks are invoked cross-CPU
+	 * on shared-cache wakeups, but amd_pstate_sample() and the bare wrmsrq
+	 * below must touch the local CPU's MSRs.
+	 */
+	if (smp_processor_id() != cpudata->cpu)
+		return;
+
+	if (time - cpudata->dyn_epp_last_sample < AMD_PSTATE_DYNAMIC_EPP_SAMPLE_NS)
+		return;
+	cpudata->dyn_epp_last_sample = time;
+
+	if (!READ_ONCE(dynamic_epp) || cpudata->suspended) {
+		if (cpudata->dyn_epp_active) {
+			amd_pstate_dynamic_epp_release(cpudata);
+			cpudata->dyn_epp_active = false;
+		}
+		return;
+	}
+
+	if (amd_pstate_sample(cpudata)) {
+		/* MPERF counts only in C0, TSC always: dmperf/dtsc = busy fraction */
+		busy_pct = div64_u64(cpudata->cur.mperf * 100, cpudata->cur.tsc);
+		if (busy_pct >= AMD_PSTATE_DYNAMIC_EPP_BUSY_PCT)
+			cpudata->dyn_epp_last_busy = time;
+	}
+
+	perf = READ_ONCE(cpudata->perf);
+	active = perf.max_limit_perf &&
+		 (time - cpudata->dyn_epp_last_busy < AMD_PSTATE_DYNAMIC_EPP_DECAY_NS);
+
+	/*
+	 * Purely edge-triggered: write exactly once on the inactive->active edge
+	 * and once on active->inactive.
+	 */
+	if (active && !cpudata->dyn_epp_active)
+		amd_pstate_dynamic_epp_apply(cpudata,
+					     READ_ONCE(cpudata->cppc_req_cached));
+	else if (!active && cpudata->dyn_epp_active)
+		amd_pstate_dynamic_epp_release(cpudata);
+
+	cpudata->dyn_epp_active = active;
+}
+
+static void amd_pstate_dynamic_epp_register(struct cpufreq_policy *policy)
+{
+	struct amd_cpudata *cpudata = policy->driver_data;
+
+	if (!cpu_feature_enabled(X86_FEATURE_CPPC))
+		return;
+
+	cpufreq_add_update_util_hook(policy->cpu, &cpudata->dyn_epp_update_util,
+				     amd_pstate_dynamic_epp_update_util);
+	cpudata->dyn_epp_registered = true;
+}
+
+static void amd_pstate_dynamic_epp_unregister(struct cpufreq_policy *policy)
+{
+	struct amd_cpudata *cpudata = policy->driver_data;
+
+	if (!cpudata->dyn_epp_registered)
+		return;
+
+	cpufreq_remove_update_util_hook(policy->cpu);
+	synchronize_rcu();
+	cpudata->dyn_epp_registered = false;
+}
+
 static int amd_pstate_epp_cpu_init(struct cpufreq_policy *policy)
 {
 	struct amd_cpudata *cpudata;
@@ -1522,7 +1730,7 @@ static int amd_pstate_epp_cpu_init(struct cpufreq_policy *policy)
 
 	current_pstate_driver->adjust_perf = NULL;
 
-	current_pstate_driver->adjust_perf = NULL;
+	amd_pstate_dynamic_epp_register(policy);
 
 	return 0;
 
@@ -1539,6 +1747,15 @@ static void amd_pstate_epp_cpu_exit(struct cpufreq_policy *policy)
 	if (cpudata) {
 		union perf_cached perf = READ_ONCE(cpudata->perf);
 
+		amd_pstate_dynamic_epp_unregister(policy);
+
+		/*
+		 * Drop the boost first (symmetric with offline/suspend) so the
+		 * reset's value==prev dedup can't skip a real write while the MSR
+		 * still carries EPP=0.
+		 */
+		amd_pstate_dynamic_epp_clear(cpudata);
+
 		/* Reset CPPC_REQ MSR to the BIOS value */
 		amd_pstate_update_perf(policy, perf.bios_min_perf, 0U, 0U, 0U, false);
 
@@ -1604,6 +1821,9 @@ static int amd_pstate_cpu_offline(struct cpufreq_policy *policy)
 	struct amd_cpudata *cpudata = policy->driver_data;
 	union perf_cached perf = READ_ONCE(cpudata->perf);
 
+	/* Drop the boost first so the reset's dedup can't skip a real write */
+	amd_pstate_dynamic_epp_clear(cpudata);
+
 	/*
 	 * Reset CPPC_REQ MSR to the BIOS value, this will allow us to retain the BIOS specified
 	 * min_perf value across kexec reboots. If this CPU is just onlined normally after this, the
@@ -1622,6 +1842,14 @@ static int amd_pstate_suspend(struct cpufreq_policy *policy)
 	union perf_cached perf = READ_ONCE(cpudata->perf);
 	int ret;
 
+	/*
+	 * Latch suspended before touching the MSR so the update-util hook cannot
+	 * re-activate the boost, then drop the boost so the reset's dedup can't
+	 * skip a real write while the MSR still holds it.
+	 */
+	cpudata->suspended = true;
+	amd_pstate_dynamic_epp_clear(cpudata);
+
 	/*
 	 * Reset CPPC_REQ MSR to the BIOS value, this will allow us to retain the BIOS specified
 	 * min_perf value across kexec reboots. If this CPU is just resumed back without kexec,
@@ -1635,9 +1863,6 @@ static int amd_pstate_suspend(struct cpufreq_policy *policy)
 	if (ret)
 		return ret;
 
-	/* set this flag to avoid setting core offline*/
-	cpudata->suspended = true;
-
 	return 0;
 }
 
