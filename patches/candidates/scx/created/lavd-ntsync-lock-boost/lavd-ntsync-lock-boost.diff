+    fn attach_ntsync_fexit(skel: &mut OpenBpfSkel) -> Result<bool> {
+        // ntsync is a loadable module (CONFIG_NTSYNC=m). An fexit program
+        // resolves its attach target from the module's BTF, which only exists
+        // once the module is loaded, so skip cleanly when it is absent --
+        // otherwise enabling these programs would fail the whole skel load.
+        if std::path::Path::new("/sys/kernel/btf/ntsync").exists() == false {
+            return Ok(false);
+        }
+
+        // Both hooks are the ioctl dispatchers in ntsync's file_operations, so
+        // they are never inlined and always resolvable by name (unlike the
+        // per-op helpers). One covers the acquire path, the other the release
+        // path; the BPF programs switch on the ioctl command.
+        let fexits = vec![
+            ("ntsync_char_ioctl", &skel.progs.fexit_ntsync_char_ioctl),
+            ("ntsync_obj_ioctl", &skel.progs.fexit_ntsync_obj_ioctl),
+        ];
+
+        // fexit attaches via a BTF trampoline, not the ftrace function tracer,
+        // so this check is only a loose proxy for DYNAMIC_FTRACE support --
+        // kept for parity with attach_futex_ftraces(), which gates its fexit
+        // programs the same way.
+        if compat::tracer_available("function")? == false {
+            info!("Function tracer is not available; skipping ntsync fexit hooks.");
+            return Ok(false);
+        }
+
+        compat::cond_kprobes_enable(fexits)
+    }
+
